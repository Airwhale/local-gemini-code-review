# Copy to .env (gitignored). The runner reads this from the repo root, not CWD,
# so you configure it once here and invoke `review.py` from any project directory.

# Required: OpenRouter API key. https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the default model. The runner defaults to
# google/gemini-2.5-pro to match the Gemini Code Assist GitHub bot. Drop to
# google/gemini-2.5-flash for ~3x faster reviews with some quality loss.
# OPENROUTER_MODEL=google/gemini-2.5-pro

# Optional: identifying headers OpenRouter surfaces in its dashboard.
# OPENROUTER_HTTP_REFERER=https://github.com/Airwhale/code-review
# OPENROUTER_X_TITLE=OpenRouter Code Review
